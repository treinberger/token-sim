    "svelte-check": "^4.1.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.2",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "d3": "^7.9.0",
